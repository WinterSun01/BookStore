<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookStore</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <!-- ==================== NAVBAR ==================== -->
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">📚 BookStore</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between">
                    <!-- Левое меню -->
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Главная</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Book" asp-action="Index">Каталог</a>
                        </li>
                    </ul>

                    <!-- Корзина -->
                    <ul class="navbar-nav me-3">
                        <li class="nav-item">
                            @await Component.InvokeAsync("Cart")
                        </li>
                    </ul>

                    <!-- Логин / Регистрация -->
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            <!-- УВЕДОМЛЕНИЯ -->
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm mt-3" role="alert">
                    <strong>✓</strong> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show shadow-sm mt-3" role="alert">
                    <strong>✕</strong> @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <!-- Хлебные крошки -->
            @await Component.InvokeAsync("Breadcrumb", new { currentPageTitle = ViewData["Title"]?.ToString() ?? "" })

            @RenderBody()
        </main>
    </div>

    <!-- ==================== ФУТЕР ==================== -->
    <footer class="bg-dark text-white pt-5 pb-4 mt-5">
        <div class="container">
            <div class="row">
                <!-- О компании -->
                <div class="col-md-4 mb-4">
                    <h5 class="fw-bold mb-3">📚 BookStore</h5>
                    <p class="text-white-50 small">
                        Ваш надёжный партнёр в мире книг с 2020 года.<br>
                        Более 50 000 книг, быстрая доставка и отличный сервис.
                    </p>
                    <div class="mt-3">
                        <a href="#" class="text-white me-3 fs-5" title="Telegram"><i class="bi bi-telegram"></i></a>
                        <a href="#" class="text-white me-3 fs-5" title="Youtube"><i class="bi bi-youtube"></i></a>
                        <a href="#" class="text-white me-3 fs-5" title="TikTok"><i class="bi bi-tiktok"></i></a>
                    </div>
                </div>

                <!-- Полезные ссылки -->
                <div class="col-md-3 mb-4">
                    <h6 class="fw-bold mb-3">Полезные ссылки</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a asp-controller="Info" asp-action="Index" asp-fragment="about" class="text-white-50 text-decoration-none">О нас</a></li>
                        <li class="mb-2"><a asp-controller="Info" asp-action="Index" asp-fragment="delivery" class="text-white-50 text-decoration-none">Доставка и оплата</a></li>
                        <li class="mb-2"><a asp-controller="Info" asp-action="Index" asp-fragment="return" class="text-white-50 text-decoration-none">Возврат и обмен</a></li>
                        <li class="mb-2"><a asp-controller="Info" asp-action="Index" asp-fragment="faq" class="text-white-50 text-decoration-none">Часто задаваемые вопросы</a></li>
                    </ul>
                </div>

                <!-- Контакты -->
                <div class="col-md-3 mb-4">
                    <h6 class="fw-bold mb-3">Контакты</h6>
                    <ul class="list-unstyled text-white-50 small">
                        <li class="mb-2">📍 г. Москва, ул. Книжная, д. 15</li>
                        <li class="mb-2">📞 +7 (495) 123-45-67</li>
                        <li class="mb-2">✉️ info@bookstore.ru</li>
                        <li>🕐 Пн–Пт: 9:00–21:00</li>
                    </ul>
                </div>

                <!-- Подписка -->
                <div class="col-md-2 mb-4">
                    <h6 class="fw-bold mb-3">Подписка</h6>
                    <p class="text-white-50 small">Получайте новости о новинках и скидках</p>
                    <form id="subscribeForm" onsubmit="subscribeUser(event)">
                        <div class="input-group input-group-sm">
                            <input type="email" id="subscribeEmail" class="form-control" placeholder="Ваш email" required>
                            <button class="btn btn-primary" type="submit">→</button>
                        </div>
                    </form>
                    <div id="subscribeMessage" class="text-success small mt-2" style="display: none;">
                        ✓ Спасибо за подписку!
                    </div>
                </div>
            </div>

            <hr class="my-4 border-secondary">

            <!-- Копирайт -->
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start">
                    <p class="mb-0 text-white-50 small">
                        &copy; 2026 BookStore. Все права защищены.
                    </p>
                </div>
                <div class="col-md-6 text-center text-md-end mt-2 mt-md-0">
                    <a href="#" class="text-white-50 text-decoration-none small me-3">Политика конфиденциальности</a>
                    <a href="#" class="text-white-50 text-decoration-none small">Пользовательское соглашение</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        function subscribeUser(e) {
            e.preventDefault();
            const email = document.getElementById('subscribeEmail').value;
            const messageDiv = document.getElementById('subscribeMessage');
            const form = document.getElementById('subscribeForm');

            messageDiv.style.display = 'block';
            messageDiv.innerHTML = `✓ Спасибо за подписку! (${email})`;
            form.reset();

            setTimeout(() => {
                messageDiv.style.display = 'none';
            }, 4000);
        }
    </script>
</body>
</html>
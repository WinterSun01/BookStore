@model IEnumerable<BookStore.Models.Entities.Book>

@{
    ViewData["Title"] = "Управление книгами";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="mb-4">📚 Управление книгами</h2>

<!-- Форма поиска -->
<div class="card mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3 align-items-end">
            <div class="col-md-6">
                <label class="form-label">Поиск по названию, автору, издательству или жанру</label>
                <input type="text" name="searchTerm" value="@ViewBag.SearchTerm"
                       class="form-control" placeholder="Введите текст для поиска..." />
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100">🔍 Найти</button>
            </div>
            <div class="col-md-3">
                <a asp-action="Index" class="btn btn-outline-secondary w-100">Сбросить</a>
            </div>
        </form>
    </div>
</div>

<!-- Кнопка добавления -->
<div class="mb-3">
    <a asp-area="Admin" asp-controller="Book" asp-action="Create"
       class="btn btn-success">
        <i class="bi bi-plus-circle"></i> + Добавить новую книгу
    </a>
</div>

<!-- Таблица книг -->
<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Обложка</th>
                <th>Название</th>
                <th>Автор</th>
                <th>Категория</th>
                <th>Издательство</th>
                <th>Цена</th>
                <th>На складе</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var book in Model)
            {
                <tr>
                    <td>
                        @if (!string.IsNullOrEmpty(book.ImageUrl))
                        {
                            <img src="@book.ImageUrl" width="50" height="70"
                                 style="object-fit:cover; border-radius: 4px;" alt="@book.Title">
                        }
                        else
                        {
                            <span class="text-muted">нет</span>
                        }
                    </td>
                    <td><strong>@book.Title</strong></td>
                    <td>@book.Author?.FullName</td>
                    <td>@book.Category?.Name</td>
                    <td>@book.Publisher?.Name</td>
                    <td class="text-success fw-bold">@book.Price.ToString("#,0") ₽</td>
                    <td>@book.Stock шт.</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@book.Id" class="btn btn-primary btn-sm me-2">Изменить</a>
                        <a asp-action="Delete" asp-route-id="@book.Id" class="btn btn-danger btn-sm">Удалить</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
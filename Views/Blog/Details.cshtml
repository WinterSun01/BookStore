@model BookStore.Models.Entities.Article

@{
    ViewData["Title"] = Model.Title;
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <a asp-action="Index" class="btn btn-outline-secondary mb-4">
                ← Назад к статьям
            </a>

            <h1 class="mb-3">@Model.Title</h1>

            <p class="text-muted mb-4">
                Опубликовано: @Model.PublishedAt.ToString("dd MMMM yyyy")
            </p>

            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" class="img-fluid rounded mb-4" style="max-height: 400px; width: 100%; object-fit: cover;" alt="@Model.Title">
            }

            <div class="article-content mb-5">
                @Html.Raw(Model.Content)
            </div>

            @if (Model.Books != null && Model.Books.Any())
            {
                <div class="card mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Книги, упомянутые в статье</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            @foreach (var book in Model.Books)
                            {
                                <div class="col-md-6 mb-3">
                                    <div class="d-flex">
                                        @if (!string.IsNullOrEmpty(book.ImageUrl))
                                        {
                                            <img src="@book.ImageUrl"
                                                 style="width: 60px; height: 80px; object-fit: cover; margin-right: 12px;"
                                                 class="rounded" alt="@book.Title">
                                        }
                                        <div>
                                            <a asp-controller="Book" asp-action="Details" asp-route-id="@book.Id" class="fw-bold">
                                                @book.Title
                                            </a>
                                            <div class="text-muted small">@book.Author?.FullName</div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }

        </div>
    </div>
</div>
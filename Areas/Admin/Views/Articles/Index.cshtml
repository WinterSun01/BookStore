@model IEnumerable<BookStore.Models.Entities.Article>

@{
    ViewData["Title"] = "Статьи и подборки";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">
        📝Статьи и подборки
    </h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Добавить статью
    </a>
</div>

@if (!Model.Any())
{
    <div class="card shadow-sm">
        <div class="card-body text-center py-5">
            <i class="bi bi-journal-text display-4 text-muted"></i>
            <h5 class="mt-3">Пока нет ни одной статьи</h5>
            <p class="text-muted">Создайте первую статью или подборку книг.</p>
            <a asp-action="Create" class="btn btn-primary mt-2">
                <i class="bi bi-plus-lg"></i> Создать статью
            </a>
        </div>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 45%;">Заголовок</th>
                            <th>Дата публикации</th>
                            <th>Статус</th>
                            <th>Книг</th>
                            <th style="width: 200px;" class="text-end">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var article in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@article.Title</strong>
                                    @if (!string.IsNullOrEmpty(article.ShortDescription))
                                    {
                                        <br>
                                        <small class="text-muted">@article.ShortDescription</small>
                                    }
                                </td>
                                <td>@article.PublishedAt.ToString("dd.MM.yyyy")</td>
                                <td>
                                    @if (article.IsPublished)
                                    {
                                        <span class="badge bg-success">Опубликовано</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Черновик</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark">@article.Books.Count</span>
                                </td>
                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@article.Id"
                                       class="btn btn-sm btn-outline-primary me-1">
                                        <i class="bi bi-pencil"></i> Редактировать
                                    </a>
                                    <form asp-action="Delete" method="post" class="d-inline"
                                          onsubmit="return confirm('Удалить эту статью?');">
                                        <input type="hidden" name="id" value="@article.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
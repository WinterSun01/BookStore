@model ErrorViewModel
@{
    ViewData["Title"] = "Ошибка";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <h1 class="text-danger display-4">Что-то пошло не так...</h1>
            <h2 class="text-muted mt-3">Произошла ошибка при обработке вашего запроса.</h2>

            @if (Model.ShowRequestId)
            {
                <p class="mt-4">
                    <strong>Идентификатор запроса:</strong>
                    <code>@Model.RequestId</code>
                </p>
            }

            <div class="alert alert-info mt-5">
                <p>Попробуйте обновить страницу или вернуться на <a asp-controller="Home" asp-action="Index">главную</a>.</p>
                <p class="small text-muted">Если ошибка повторяется, свяжитесь с поддержкой.</p>
            </div>

            <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg mt-3">
                ← Вернуться на главную
            </a>
        </div>
    </div>
</div>
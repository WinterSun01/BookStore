@model BookStore.Models.Entities.Publisher

@{
    ViewData["Title"] = "Добавить издательство";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="mb-4">➕ Добавить издательство</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label">Название издательства</label>
                <input asp-for="Name" class="form-control" placeholder="Например: Эксмо" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Country" class="form-label">Страна</label>
                <input asp-for="Country" class="form-control" placeholder="Например: Россия" />
                <span asp-validation-for="Country" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success">
                    <i class="bi bi-check-circle"></i> Сохранить
                </button>
                <a asp-action="Index" class="btn btn-secondary">Отмена</a>
            </div>
        </form>
    </div>
</div>
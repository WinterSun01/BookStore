@model IEnumerable<BookStore.Models.Entities.Article>

@{
    ViewData["Title"] = "Блог и подборки";
}

<h2 class="mb-4">📇 Блог и книжные подборки</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Пока нет опубликованных статей.
    </div>
}
else
{
    <div class="row">
        @foreach (var article in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 shadow-sm">
                    @if (!string.IsNullOrEmpty(article.ImageUrl))
                    {
                        <img src="@article.ImageUrl" class="card-img-top" style="height: 180px; object-fit: cover;" alt="@article.Title">
                    }
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@article.Title</h5>

                        @if (!string.IsNullOrEmpty(article.ShortDescription))
                        {
                            <p class="card-text text-muted">@article.ShortDescription</p>
                        }

                        <div class="mt-auto">
                            <small class="text-muted d-block mb-2">
                                @article.PublishedAt.ToString("dd MMMM yyyy")
                            </small>

                            <a asp-action="Details" asp-route-slug="@article.Slug"
                               class="btn btn-outline-primary w-100">
                                Читать →
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
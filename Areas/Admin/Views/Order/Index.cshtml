@model IEnumerable<BookStore.Models.Entities.Order>

@{
    ViewData["Title"] = "Все заказы";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="mb-4">📦 Все заказы</h2>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>№ Заказа</th>
                <th>Дата</th>
                <th>Пользователь</th>
                <th>Сумма</th>
                <th>Статус</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model)   
            {
                <tr>
                    <td><strong>@order.Id</strong></td>
                    <td>@order.OrderDate.ToString("dd.MM.yyyy HH:mm")</td>
                    
                    <td>
                        @if (order.User != null)
                        {
                            @order.User.UserName
                        }
                        else
                        {
                            <span class="text-muted">Неизвестный пользователь</span>
                        }
                    </td>
                    
                    <td class="text-success fw-bold">@order.TotalAmount.ToString("C0")</td>

                    <td>
                        <span class="badge bg-@(order.Status == "Paid" ? "success" :
                                                              order.Status == "AwaitingPayment" ? "warning" : "secondary")">
                        @order.GetStatusDisplay()
                    </span>
                </td>
                    
                    <td>
                        <a asp-action="Details" asp-route-id="@order.Id" 
                           class="btn btn-info btn-sm">Подробнее</a>
                        
                        <div class="btn-group">
                            <form asp-action="ChangeStatus" method="post" style="display:inline;">
                                <input type="hidden" name="id" value="@order.Id" />
                                <button type="submit" name="status" value="Paid" 
                                        class="btn btn-success btn-sm">Оплачен</button>
                            </form>
                            <form asp-action="ChangeStatus" method="post" style="display:inline;">
                                <input type="hidden" name="id" value="@order.Id" />
                                <button type="submit" name="status" value="Shipped" 
                                        class="btn btn-primary btn-sm">Отправлен</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
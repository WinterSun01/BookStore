@model IEnumerable<BookStore.Models.Entities.Author>

@{
    ViewData["Title"] = "Управление авторами";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>👤 Управление авторами</h2>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Добавить автора
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Авторы ещё не добавлены.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>ФИО</th>
                    <th>Биография</th>
                    <th style="width: 200px;">Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var author in Model)
                {
                    <tr>
                        <td><strong>@author.FullName</strong></td>
                        <td>
                            @if (!string.IsNullOrEmpty(author.Biography))
                            {
                                <span class="text-muted">@author.Biography</span>
                            }
                            else
                            {
                                <span class="text-muted fst-italic">—</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@author.Id" class="btn btn-primary btn-sm me-1">
                                <i class="bi bi-pencil"></i> Изменить
                            </a>
                            <a asp-action="Delete" asp-route-id="@author.Id" class="btn btn-danger btn-sm">
                                <i class="bi bi-trash"></i> Удалить
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
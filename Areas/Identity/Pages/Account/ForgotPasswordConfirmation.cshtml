@page
@model BookStore.Areas.Identity.Pages.Account.ForgotPasswordConfirmationModel
@{
    ViewData["Title"] = "Письмо отправлено";
}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm text-center p-4">
                <h4>Проверьте вашу почту</h4>
                <p class="text-muted">Если аккаунт с таким email существует, мы отправили ссылку для сброса пароля.</p>
                <a asp-page="./Login" class="btn btn-primary mt-3">Вернуться на страницу входа</a>
            </div>
        </div>
    </div>
</div>
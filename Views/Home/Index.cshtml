@model IEnumerable<BookStore.Models.Entities.Book>
@{
    ViewData["Title"] = "BookStore - Интернет-магазин книг";
}

<div class="jumbotron text-center py-5" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border-radius: 15px; margin-bottom: 3rem;">
    <div class="container">
        <h1 class="display-4 fw-bold">Добро пожаловать в BookStore</h1>
        <p class="lead fs-4 mt-3">Лучшие книги по лучшим ценам.<br>Более 10 000 довольных читателей.</p>
        <a asp-controller="Book" asp-action="Index" class="btn btn-light btn-lg px-5 mt-4 shadow">
            Перейти в каталог →
        </a>
    </div>
</div>

<div class="container mb-5">
    <h2 class="text-center mb-4">Почему выбирают нас</h2>
    <div class="row text-center">
        <div class="col-md-4 mb-4">
            <div class="p-4">
                <div class="display-4 mb-3">📚</div>
                <h5>Огромный выбор</h5>
                <p class="text-muted">Более 50 000 книг в наличии. От классики до новинок.</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="p-4">
                <div class="display-4 mb-3">🚚</div>
                <h5>Быстрая доставка</h5>
                <p class="text-muted">Доставка по всей России за 1–3 дня. Бесплатно от 2000 ₽.</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="p-4">
                <div class="display-4 mb-3">💯</div>
                <h5>Гарантия качества</h5>
                <p class="text-muted">Только оригинальные издания. 30 дней на возврат.</p>
            </div>
        </div>
    </div>
</div>

<div class="container mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Новинки и популярные книги</h2>
        <a asp-controller="Book" asp-action="Index" class="btn btn-outline-primary">Смотреть все →</a>
    </div>

    <div class="row">
        @foreach (var book in Model.Take(6))
        {
            <div class="col-12 col-sm-6 col-md-4 col-lg-2 mb-4">
                <div class="card h-100 shadow-sm border-0 d-flex flex-column">

                    @if (!string.IsNullOrEmpty(book.ImageUrl))
                    {
                        <img src="@book.ImageUrl"
                             class="card-img-top"
                             style="height: 230px; object-fit: contain; background-color: #f8f9fa; padding: 8px;"
                             alt="@book.Title">
                    }

                    <div class="card-body d-flex flex-column flex-grow-1 p-2">

                        <div class="flex-grow-1">
                            <h6 class="card-title mb-1" style="font-size: 0.95rem; line-height: 1.3; min-height: 2.4em;">
                                @book.Title
                            </h6>
                            <p class="card-text text-muted small mb-2">@book.Author?.FullName</p>

                            <div class="mb-2 d-flex align-items-center" style="min-height: 20px;">
                                @{
                                    var rating = 0.0;
                                    if (ViewBag.BookRatings != null && ViewBag.BookRatings.ContainsKey(book.Id))
                                    {
                                        rating = (double)ViewBag.BookRatings[book.Id];
                                    }
                                }

                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (rating >= i)
                                    {
                                        <i class="bi bi-star-fill text-warning" style="font-size: 0.85rem;"></i>
                                    }
                                    else if (rating >= i - 0.5)
                                    {
                                        <i class="bi bi-star-half text-warning" style="font-size: 0.85rem;"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-star text-warning" style="font-size: 0.85rem;"></i>
                                    }
                                }

                                @if (rating > 0)
                                {
                                    <span class="ms-1 fw-bold small">@rating.ToString("0.0")</span>
                                }
                            </div>
                        </div>

                        <div class="mt-auto">
                            <p class="text-success fw-bold mb-2">@book.Price.ToString("#,0") ₽</p>
                            <a asp-controller="Book" asp-action="Details" asp-route-id="@book.Id"
                               class="btn btn-outline-primary btn-sm w-100">Подробнее</a>
                        </div>

                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="container">
    <div class="text-center py-5 bg-light rounded-3">
        <h3>Не нашли то, что искали?</h3>
        <p class="lead">В нашем каталоге более 50 000 книг. Найдите свою следующую любимую книгу прямо сейчас.</p>
        <a asp-controller="Book" asp-action="Index" class="btn btn-primary btn-lg px-5">Перейти в каталог</a>
    </div>
</div>
@model BookStore.Models.Entities.Author

@{
    ViewData["Title"] = "Удалить автор";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="mb-4 text-danger">🗑️ Удалить автора</h2>

<div class="alert alert-warning">
    <strong>Внимание!</strong> Вы уверены, что хотите удалить этого автора?
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <h5>@Model.FullName</h5>

        @if (!string.IsNullOrEmpty(Model.Biography))
        {
            <p class="text-muted">@Model.Biography</p>
        }

        <form asp-action="Delete" method="post" class="mt-4">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash"></i> Да, удалить
                </button>
                <a asp-action="Index" class="btn btn-secondary">Отмена</a>
            </div>
        </form>
    </div>
</div>
@model IEnumerable<BookStore.Models.Entities.Publisher>

@{
    ViewData["Title"] = "Управление издательствами";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>🏢 Управление издательствами</h2>
    
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Добавить издательство
    </a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Название</th>
                <th>Страна</th>
                <th style="width: 180px;">Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var pub in Model)
            {
                <tr>
                    <td><strong>@pub.Name</strong></td>
                    <td>@pub.Country</td>
                    <td>
                        <a asp-action="Edit" 
                           asp-route-id="@pub.Id" 
                           class="btn btn-primary btn-sm me-1">Изменить</a>
                        
                        <a asp-action="Delete" 
                           asp-route-id="@pub.Id" 
                           class="btn btn-danger btn-sm">Удалить</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
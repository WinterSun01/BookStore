@model BookStore.Models.Entities.Category

@{
    ViewData["Title"] = "Добавить категорию";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="mb-4">➕ Добавить категорию</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Create" method="post">
            
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label">Название категории</label>
                <input asp-for="Name" class="form-control" placeholder="Например: Фантастика" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Description" class="form-label">Описание</label>
                <textarea asp-for="Description" class="form-control" rows="3" 
                          placeholder="Краткое описание категории..."></textarea>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success">Сохранить</button>
                
                <a asp-action="Index" class="btn btn-secondary">Отмена</a>
            </div>
        </form>
    </div>
</div>
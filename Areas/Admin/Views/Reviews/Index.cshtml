@model List<BookStore.Models.Entities.Review>

@{
    ViewData["Title"] = "Модерация отзывов";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">
            <i class="bi bi-chat-left-text text-primary"></i> Отзывы на модерацию
        </h2>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model == null || !Model.Any())
    {
        <div class="card shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-inbox display-4 text-muted"></i>
                <h5 class="mt-3">Нет отзывов на модерацию</h5>
                <p class="text-muted">Все отзывы уже проверены.</p>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 140px;">Дата</th>
                                <th>Книга</th>
                                <th>Пользователь</th>
                                <th style="width: 100px;">Оценка</th>
                                <th>Отзыв</th>
                                <th style="width: 200px;" class="text-end">Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var review in Model)
                            {
                                <tr>
                                    <td class="text-muted small">
                                        @review.CreatedAt.ToString("dd.MM.yyyy")<br>
                                        <span class="text-muted">@review.CreatedAt.ToString("HH:mm")</span>
                                    </td>
                                    <td>
                                        <strong>@review.Book?.Title</strong>
                                    </td>
                                    <td>
                                        @(!string.IsNullOrEmpty(review.User?.FirstName) ? review.User.FirstName : review.User?.UserName)
                                    </td>
                                    <td>
                                        @if (review.Rating > 0)
                                        {
                                            @for (int i = 1; i <= review.Rating; i++)
                                            {
                                                <span style="color: #ffc107; font-size: 1.2rem;">★</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td style="max-width: 400px;">
                                        <p class="mb-0">@review.Comment</p>
                                    </td>
                                    <td class="text-end">
                                        <div class="d-flex justify-content-end gap-2">
                                            <form asp-action="Approve" method="post">
                                                <input type="hidden" name="id" value="@review.Id" />
                                                <button type="submit" class="btn btn-success btn-sm">
                                                    <i class="bi bi-check-lg"></i> Опубликовать
                                                </button>
                                            </form>

                                            <form asp-action="Delete" method="post">
                                                <input type="hidden" name="id" value="@review.Id" />
                                                <button type="submit" class="btn btn-outline-danger btn-sm"
                                                        onclick="return confirm('Удалить этот отзыв?');">
                                                    <i class="bi bi-trash"></i> Удалить
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>
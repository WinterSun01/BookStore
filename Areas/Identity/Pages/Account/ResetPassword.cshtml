@page
@using BookStore.Areas.Identity.Pages.Account
@model ResetPasswordModel
@{
    ViewData["Title"] = "Сброс пароля";
}
<div class="container mt-5">
    <div class="card shadow">
        <div class="card-body">
            <h3 class="mb-3">Сброс пароля</h3>
            <form method="post">
                <input type="hidden" asp-for="Input.Email" />
                <input type="hidden" asp-for="Input.Code" />
                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label">
                        Новый пароль
                    </label>
                    <input asp-for="Input.Password" class="form-control" />
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Input.ConfirmPassword" class="form-label">
                        Подтвердите пароль
                    </label>
                    <input asp-for="Input.ConfirmPassword" class="form-control" />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                </div>
                <button type="submit" class="btn btn-primary">
                    Сменить пароль
                </button>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
@page
@model BookStore.Areas.Identity.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Восстановление пароля";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h3>Восстановление пароля</h3>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted mb-4">
                        Введите адрес электронной почты, указанный при регистрации.
                        Мы отправим вам ссылку для сброса пароля.
                    </p>

                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-4">
                            <label asp-for="Input.Email" class="form-label">Электронная почта</label>
                            <input asp-for="Input.Email" class="form-control" placeholder="name@example.com" />
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100">
                            Отправить ссылку для сброса пароля
                        </button>
                    </form>
                </div>
                <div class="card-footer text-center py-3">
                    <a asp-page="./Login" class="text-decoration-none">Вернуться на страницу входа</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
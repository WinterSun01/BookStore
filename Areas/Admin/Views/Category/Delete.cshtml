@model BookStore.Models.Entities.Category

@{
    ViewData["Title"] = "Удалить категорию";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="mb-4 text-danger">🗑️ Удалить категорию</h2>

<div class="alert alert-warning">
    <strong>Внимание!</strong> Вы уверены, что хотите удалить эту категорию?
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <h5>@Model.Name</h5>
        
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p class="text-muted">@Model.Description</p>
        }

        <form asp-action="Delete" method="post" class="mt-4">
            
            <input type="hidden" asp-for="Id" />
            
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash"></i> Да, удалить
                </button>
                
                <a asp-action="Index" class="btn btn-secondary">Отмена</a>
            </div>
        </form>
    </div>
</div>
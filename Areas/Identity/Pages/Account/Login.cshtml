@page
@model BookStore.Areas.Identity.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Вход в аккаунт";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h3>Вход в BookStore</h3>
                </div>
                <div class="card-body p-4">
                    <form id="account" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Input.Email" class="form-label">Электронная почта</label>
                            <input asp-for="Input.Email" class="form-control" placeholder="name@example.com" />
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Password" class="form-label">Пароль</label>
                            <input asp-for="Input.Password" class="form-control" type="password" />
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>

                        <div class="form-check mb-3">
                            <input class="form-check-input" asp-for="Input.RememberMe" />
                            <label asp-for="Input.RememberMe" class="form-check-label">Запомнить меня</label>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100 mb-3">
                            Войти
                        </button>

                        <div class="text-center">
                            <a asp-page="./ForgotPassword" class="text-decoration-none">Забыли пароль?</a>
                        </div>
                    </form>
                </div>
                <div class="card-footer text-center py-3">
                    <p class="mb-0">
                        Нет аккаунта?
                        <a asp-page="./Register" class="text-primary fw-bold">Зарегистрироваться</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
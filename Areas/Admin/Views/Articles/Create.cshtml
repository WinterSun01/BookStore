@model BookStore.Models.Entities.Article

@{
    ViewData["Title"] = "Создать статью";
    var books = ViewBag.Books as List<BookStore.Models.Entities.Book> ?? new List<BookStore.Models.Entities.Book>();
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="mb-4">
    <i class="bi bi-plus-circle text-primary"></i> Создать статью / подборку
</h2>

<form asp-action="Create" method="post">
    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Заголовок статьи *</label>
                        <input asp-for="Title" class="form-control" placeholder="Например: Лучшие книги 2025 года" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Краткое описание</label>
                        <textarea asp-for="ShortDescription" class="form-control" rows="2"
                                  placeholder="Кратко опишите, о чём статья (отображается в списке)"></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Содержание статьи *</label>
                        <textarea asp-for="Content" class="form-control" rows="14"
                                  placeholder="Здесь можно использовать HTML-разметку"></textarea>
                        <small class="text-muted">Поддерживается HTML</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Изображение (URL)</label>
                        <input asp-for="ImageUrl" class="form-control" placeholder="https://example.com/image.jpg" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Дата публикации</label>
                        <input asp-for="PublishedAt" class="form-control" type="datetime-local"
                               value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                    </div>

                    <div class="form-check form-switch mb-3">
                        <input asp-for="IsPublished" class="form-check-input" role="switch" checked>
                        <label class="form-check-label">Опубликовать сразу</label>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h6 class="mb-0">Связанные книги</h6>
                </div>
                <div class="card-body">
                    @if (books.Any())
                    {
                        <select name="selectedBooks" class="form-select" multiple size="10">
                            @foreach (var book in books)
                            {
                                <option value="@book.Id">@book.Title</option>
                            }
                        </select>
                        <small class="text-muted d-block mt-2">
                            Можно выбрать несколько книг (удерживайте <kbd>Ctrl</kbd>)
                        </small>
                    }
                    else
                    {
                        <p class="text-muted mb-0">В базе пока нет книг.</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <button type="submit" class="btn btn-primary px-4">
            <i class="bi bi-check-lg"></i> Создать статью
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary ms-2">Отмена</a>
    </div>
</form>